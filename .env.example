# AgentForge Environment Configuration
# Copy this file to .env and fill in your values

# ── LLM API Keys ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=               # optional — only needed if using Claude models
OPENAI_API_KEY=sk-...            # required — used for all LLM calls (gpt-4o-mini)

# ── Model Selection ────────────────────────────────────────────────────────────
DEFAULT_MODEL=gpt-4o-mini
PLANNER_MODEL=gpt-4o-mini
ROUTER_MODEL=gpt-4o-mini

# ── Vector Database (Qdrant) — Phase 2 ────────────────────────────────────────
QDRANT_URL=http://localhost:6333

# ── Observability (Langfuse) — Phase 4 ────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ── Research Engine ────────────────────────────────────────────────────────────
RESEARCH_CACHE_TTL_DAYS=7
MAX_SEARCH_QUERIES_PER_JOB=5
MAX_PAGES_TO_FETCH=3
ENABLE_MCP_DISCOVERY=true

# ── MCP Servers ────────────────────────────────────────────────────────────────
MCP_SERVERS=[]

# ── Workflow Engine (Temporal) — Phase 3 ──────────────────────────────────────
TEMPORAL_HOST=localhost:7233

# ── System Limits ─────────────────────────────────────────────────────────────
MAX_CONCURRENT_JOBS=10
